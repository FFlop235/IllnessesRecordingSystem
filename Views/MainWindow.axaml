<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IllnessesRecordingSystem.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1016" d:DesignHeight="500"
        x:Class="IllnessesRecordingSystem.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/virus.ico"
        Title="Система учёта заболеваний"
        Width="1016" Height="500">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <TabControl>
        <TabItem Header="Записи">
            <Grid RowDefinitions="* Auto Auto">
        <DataGrid 
            ItemsSource="{Binding IllnessRecords}"
            GridLinesVisibility="All"
            BorderThickness="1"
            BorderBrush="Gray"
            IsReadOnly="True"
            SelectedItem="{Binding SelectedIllnessRecord}"
            DoubleTapped="EditRecordDoubleTap">
            <DataGrid.Columns>
                <!--<DataGridTextColumn Header="ID" Binding="{Binding Id}"/>-->
                <DataGridTextColumn Header="Имя" Binding="{Binding EmployeeName}"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding DepartmentName}"/>
                <DataGridTextColumn Header="Тип заболевания" Binding="{Binding IllnessType}"/>
                <DataGridTextColumn Header="Начало болезни" Binding="{Binding StartDate, StringFormat='dd.MM.yyyy'}"/>
                <DataGridTextColumn Header="Окончание болезни" Binding="{Binding EndDate, StringFormat='dd.MM.yyyy'}"/>
                <DataGridTextColumn Header="Дни болезни" Binding="{Binding DurationDays}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10"
                    Spacing="10">
            <Button Content="Добавить" Command="{Binding OpenAddWindow}"/>
            <Button Content="Удалить" Command="{Binding DeleteSelectedIllnessRecord}"/>
        </StackPanel>
        <StackPanel 
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Center">
                <Button Content="&lt;&lt;" Command="{Binding ShowFirstPageCommand}"/>
                <Button Content="&lt;" Command="{Binding ShowPreviousPage}"/>
                <Label Content="{Binding PageInfo}"/>
                <Button Content="&gt;" Command="{Binding ShowNextPageCommand}"/>
                <Button Content="&gt;&gt;" Command="{Binding ShowLastPageCommand}"/>
                <Label Content="Кол-во записей на странице:"/>
                <ComboBox ItemsSource="{Binding PageSizes}"
                          SelectedItem="{Binding CurrentPageSize}"/>
        </StackPanel>
    </Grid>
        </TabItem>
        <TabItem Header="Статистика">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="10" Spacing="10">
                    
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Текущее подразделение" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Подразделение:"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DepartmentsSickView.DepartmentName}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Дни болезни:"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DepartmentsSickView.TotalSickDays}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Случаи:"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DepartmentsSickView.IllnessCount}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Средняя длит.:"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DepartmentsSickView.AvgDuration, StringFormat='{}{0:F1} дн.'}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Топ-3 заболеваний" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ItemsControl ItemsSource="{Binding TopIllnesses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Длительность заболеваний" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ItemsControl ItemsSource="{Binding IllnessDurations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Самое болеющее подразделение" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ItemsControl ItemsSource="{Binding TopDepartments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Инфекционные заболевания" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding InfectiousStats.DisplayText}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Самый стойкий сотрудник" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TopEmployee.DisplayText}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
    
</Window>
