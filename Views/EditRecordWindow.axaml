<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:IllnessesRecordingSystem.ViewModels"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="300"
        x:Class="IllnessesRecordingSystem.Views.EditRecordWindow"
        x:DataType="viewModels:EditRecordViewModel"
        Title="Редактирование записи"
        Width="700" Height="300">
        <StackPanel
                Orientation="Vertical"
                Spacing="10">
                <ComboBox ItemsSource="{Binding Employees}"
                          SelectedItem="{Binding SelectedEmployee}"
                          DisplayMemberBinding="{Binding FullName}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

                <ComboBox ItemsSource="{Binding IllnessTypes}"
                          SelectedItem="{Binding SelectedIllnessType}"
                          DisplayMemberBinding="{Binding Name}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
        
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical"
                                    Spacing="1">
                                <Label Content="Начальная дата:"/>
                                <DatePicker SelectedDate="{Binding StartDate}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical"
                                    Spacing="1">
                                <Label Content="Конечная дата:"/>
                                <DatePicker SelectedDate="{Binding EndDate}"/>
                        </StackPanel>
                </StackPanel>
        
                <TextBox HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap"
                         Width="300"
                         Height="100"
                         Watermark="Введите заметку врача..."
                         Text="{Binding DiagnosisNote}"/>
                
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="30"
                            Orientation="Horizontal">
                    <Button Content="✅"
                            Command="{Binding SaveChanges}"/>
                    <Button Content="❌"
                            Command="{Binding Close}"/>
                </StackPanel>
        </StackPanel>
</Window>
